   ],
   "source": [
    "import numpy as np\n",
    "A=np.array([[27.6,30.2],\n",
    "          [3100,6400],\n",
    "          [250,360]])\n",
    "b= np.array([162, 23610, 1623])\n",
    "x = np.linalg.lstsq(A, b, rcond=None)[0]\n",
    "print(f\"煤 A 的消耗量 x1 = {x[0]:.2f} 吨\")\n",
    "print(f\"煤 B 的消耗量 x2 = {x[1]:.2f} 吨\")"
   ]
  }
